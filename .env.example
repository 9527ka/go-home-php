# ============================================
# 《回家了么》服务端环境配置
# 复制此文件为 .env 并修改配置
# ============================================

APP_DEBUG = false

# ⚠️ 重要：以下变量必须放在所有 [SECTION] 之前
# ThinkPHP 会把 [SECTION] 下的变量解析为 SECTION_KEY，导致 env('JWT_SECRET') 读不到
# ⚠️ 必须修改为随机长字符串
JWT_SECRET = "请替换为至少32位的随机字符串_openssl_rand_base64_32"

# Apple 授权登录
APPLE_BUNDLE_ID = "com.yourcompany.gohome"

# 上传配置
UPLOAD_MAX_SIZE = 5242880
UPLOAD_PATH = uploads

# CDN / 资源域名（图片等静态资源的完整URL前缀）
APP_CDN_URL = "https://your-domain.com"

# 腾讯云 TRTC（私聊语音通话） — 未配置时相关接口返回错误
# SDKSecretKey 仅用于后端生成 UserSig，绝不能下发到客户端
TRTC_SDK_APPID = ""
TRTC_SDK_SECRET = ""
TRTC_USER_SIG_EXPIRE = 86400

[APP]
DEFAULT_TIMEZONE = Asia/Shanghai

[DATABASE]
TYPE = mysql
HOSTNAME = 127.0.0.1
DATABASE = go_home
USERNAME = root
PASSWORD = your_db_password_here
HOSTPORT = 3306
CHARSET = utf8mb4
DEBUG = false
PREFIX =

[LANG]
default_lang = zh-cn

[LOG]
CHANNEL = file
